[sub_resource type="GDScript" id="GDScript_6n1o6"]
script/source = "extends Node2D


func _ready() -> void:
	if Prst.counting_down:
		hide()
		return
	show()

func _input(event: InputEvent) -> void:
	if event.is_action_pressed(\"a\") or event.is_action_pressed(\"d\"):
		hide()
"

