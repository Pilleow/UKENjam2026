[sub_resource type="GDScript" id="GDScript_3kgif"]
script/source = "extends Sprite2D

@export_node_path() var inatorMenuP
@export_node_path() var upgradesMenuP

var inatorMenu
var upgradesMenu

func _process(delta: float) -> void:
	offset.y = sin(Time.get_ticks_msec() / 1000.0) * 2.0

func _ready() -> void:
	upgradesMenu = get_node(upgradesMenuP)
	inatorMenu = get_node(inatorMenuP)
	Prst.connect(\"moneyUpdated\", tryBlink)
	Prst.connect(\"scrapUpdated\", tryBlink)
	tryBlink()

func tryBlink():
	var enterCar = get_parent().get_node(\"enterCar\")
	if not Prst.counting_down:
		enterCar.blocked = (Prst.money > 0 or inatorMenu.canBuyAnything() or upgradesMenu.canBuyAnything())
	material.set_shader_parameter(\"outline_enabled\", not enterCar.blocked)
"

